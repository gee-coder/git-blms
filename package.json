{
  "name": "easy-git",
  "displayName": "GitBlms",
  "description": "GitBlms brings GoLand-style inline Git blame to VS Code, with age buckets, uncommitted highlighting, and bilingual UI / GitBlms 为 VS Code 带来 GoLand 风格的 Git 追溯注解体验，支持时间色阶、未提交高亮和中英文界面。",
  "version": "1.0.0",
  "publisher": "gee-coder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gee-coder/easy-git.git"
  },
  "homepage": "https://github.com/gee-coder/easy-git.git",
  "bugs": {
    "url": "https://github.com/gee-coder/easy-git/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1f2532",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "blame",
    "annotate",
    "history",
    "goland",
    "scm"
  ],
  "markdown": "github",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:easy-git.toggleBlame",
    "onCommand:easy-git.showBlame",
    "onCommand:easy-git.hideBlame",
    "onCommand:easy-git.openCommitDetails"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "easy-git.toggleBlame",
        "title": "Toggle Inline Git Blame / 切换行内追溯注解",
        "category": "Git"
      },
      {
        "command": "easy-git.showBlame",
        "title": "Show Inline Git Blame / 显示行内追溯注解",
        "category": "Git"
      },
      {
        "command": "easy-git.hideBlame",
        "title": "Hide Inline Git Blame / 隐藏行内追溯注解",
        "category": "Git"
      },
      {
        "command": "easy-git.openCommitDetails",
        "title": "Open Commit Details / 查看当前行提交详情",
        "category": "Git"
      }
    ],
    "keybindings": [
      {
        "command": "easy-git.toggleBlame",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "easy-git.showBlame",
          "when": "resourceScheme == file && !easyGit.enabled",
          "group": "navigation@git-blame"
        },
        {
          "command": "easy-git.hideBlame",
          "when": "resourceScheme == file && easyGit.enabled",
          "group": "navigation@git-blame"
        },
        {
          "command": "easy-git.openCommitDetails",
          "when": "resourceScheme == file && easyGit.enabled",
          "group": "navigation@git-blame"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "easy-git.showBlame",
          "when": "resourceScheme == file && !easyGit.enabled",
          "group": "navigation@git-blame"
        },
        {
          "command": "easy-git.hideBlame",
          "when": "resourceScheme == file && easyGit.enabled",
          "group": "navigation@git-blame"
        }
      ]
    },
    "configuration": {
      "title": "GitBlms",
      "properties": {
        "easy-git.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable or disable inline Git blame annotations globally / 全局启用或关闭行内 Git 追溯注解。"
        },
        "easy-git.colorScheme": {
          "type": "string",
          "default": "blue",
          "enum": [
            "blue",
            "green",
            "purple"
          ],
          "description": "Primary annotation palette: blue, green, or purple / 注解主色调，可选 blue、green、purple。"
        },
        "easy-git.dateFormat": {
          "type": "string",
          "default": "absolute",
          "enum": [
            "relative",
            "absolute"
          ],
          "description": "Timestamp display format: relative or absolute / 时间显示格式，可选 relative 或 absolute。"
        },
        "easy-git.maxLineCount": {
          "type": "number",
          "default": 5000,
          "minimum": 1,
          "description": "Skip blame rendering for files over this line count / 超过该行数的文件会跳过 blame 渲染以保护性能。"
        },
        "easy-git.cacheTimeout": {
          "type": "number",
          "default": 60000,
          "minimum": 0,
          "description": "Blame cache lifetime in milliseconds / blame 结果缓存时长，单位毫秒。"
        },
        "easy-git.maxAnnotationWidth": {
          "type": "number",
          "default": 22,
          "minimum": 8,
          "description": "Maximum width of the left blame column in ch units / 左侧 blame 信息栏最大宽度，单位 ch。"
        },
        "easy-git.uncommittedColor": {
          "type": "string",
          "default": "46,160,67",
          "description": "Color used for uncommitted lines. Supports 46,160,67, rgb(46,160,67), or #2ea043 / 未提交代码颜色，支持 46,160,67、rgb(46,160,67) 或 #2ea043。"
        },
        "easy-git.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "description": "Extension display language: auto, zh-CN, or en / 扩展显示语言，可选 auto、zh-CN、en。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "pretest": "npm run compile",
    "test": "node --test \"out/test/**/*.test.js\"",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0"
  }
}
